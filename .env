# ──────────────────────────────────────────
# FinTracking Docker Compose 환경 변수
# 민감하지 않은 기본값만 포함합니다.
# 비밀번호 등 민감값은 .env.secret 에 작성하세요.
# ──────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=ON_SECRET

# RabbitMQ
RABBITMQ_DEFAULT_USER=ON_SECRET

# Grafana
GF_SECURITY_ADMIN_USER=ON_SECRET
GF_USERS_ALLOW_SIGN_UP=false