{
  "uid": "ft-overview",
  "title": "FinTracking — 전체 서비스 현황",
  "tags": ["fintracking", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🔢 핵심 지표 요약",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "전체 RPS",
      "description": "모든 서비스의 초당 HTTP 요청 합계. 급격한 증가는 트래픽 스파이크, 0에 가까우면 서비스 장애를 의심.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "에러율 (5xx)",
      "description": "전체 요청 중 5xx 비율. 1% 초과 시 즉시 원인 파악 필요. 부하 테스트 중 10% 이상이면 서비스 포화 상태.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count[1m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P95 응답시간 (전체)",
      "description": "상위 5% 요청이 이 시간 이상 걸림. 부하 테스트 기준: 500ms 이하 양호, 1s 이상 경고, 3s 이상 위험.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "평균 Heap 사용률",
      "description": "전체 서비스 Heap 평균 점유율. 80% 이상 지속 시 GC 압박 → 응답 지연 발생. OOM 전조 지표.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "avg(sum(jvm_memory_used_bytes{area=\"heap\"}) by (application) / sum(jvm_memory_max_bytes{area=\"heap\"}) by (application)) * 100",
          "legendFormat": "Heap %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "전체 활성 스레드",
      "description": "모든 서비스 라이브 스레드 합계. 급증하면 스레드 풀 고갈 임박. 서비스당 200+ 이면 위험.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(jvm_threads_live_threads)",
          "legendFormat": "Threads"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 800 },
              { "color": "red", "value": 1200 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "UP 서비스 수",
      "description": "Prometheus가 스크래핑 중인 정상 서비스 수. 예상 수보다 적으면 해당 서비스 확인 필요.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "count(up{job=\"spring-microservices\"} == 1)",
          "legendFormat": "UP"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 6 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background" }
    },

    {
      "id": 10,
      "type": "row",
      "title": "🌐 HTTP 트래픽",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "서비스별 RPS",
      "description": "서비스별 초당 요청 수 추이. 특정 서비스만 급증하면 해당 서비스 상세 대시보드 확인. 부하가 고르게 분산되는지 비교.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP 상태 코드 분포",
      "description": "2xx=정상, 4xx=클라이언트 오류(인증/파라미터), 5xx=서버 오류. 부하 테스트 중 5xx 증가는 포화 지점 도달 신호.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"2..\"}[1m]))",
          "legendFormat": "2xx (정상)"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx (클라이언트)"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx (서버)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx (정상)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx (클라이언트)" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx (서버)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },

    {
      "id": 20,
      "type": "row",
      "title": "⏱ 응답 시간",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "응답시간 P50 / P95 / P99 (전체)",
      "description": "P50=중간값(일반 사용자 경험), P95=상위 5% 느린 요청, P99=상위 1%. P95와 P99 격차가 크면 간헐적 스파이크 존재.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },

    {
      "id": 30,
      "type": "row",
      "title": "☕ JVM 리소스",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "서비스별 Heap 사용량",
      "description": "서비스별 Heap 메모리 사용 바이트. 지속 증가하면 메모리 릭 의심. GC 후에도 반환되지 않으면 위험.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "서비스별 CPU 사용률",
      "description": "JVM 프로세스 CPU 사용률(0~1). 0.8 이상 지속 시 CPU 포화 — 응답시간 P99 악화와 함께 확인.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "GC 발생 빈도 (서비스별)",
      "description": "분당 GC 횟수. 빈도가 높을수록 Stop-The-World 시간 증가 → P99 응답시간 상승. Heap 사용량 그래프와 함께 분석.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_count[1m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "cps", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "서비스별 라이브 스레드 수",
      "description": "JVM 라이브 스레드 수. 부하 증가에 따라 선형 증가하다 급등하면 스레드 풀 한계 도달. Deadlock 시 지속 증가.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] } }
    },

    {
      "id": 40,
      "type": "row",
      "title": "📨 도메인 & Kafka 메트릭",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "도메인 요청 처리율 (성공 / 실패)",
      "description": "ft_domain_requests_total: @Monitored 어노테이션으로 수집된 서비스 레이어 호출. fail 급증 = 비즈니스 로직 예외 급증.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "targets": [
        {
          "expr": "sum(rate(ft_domain_requests_total{result=\"success\"}[1m])) by (application)",
          "legendFormat": "성공 — {{application}}"
        },
        {
          "expr": "sum(rate(ft_domain_requests_total{result=\"fail\"}[1m])) by (application)",
          "legendFormat": "실패 — {{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Kafka 이벤트 처리율 (토픽별)",
      "description": "ft_kafka_events_total: publish=발행, consume=소비. consume fail 발생 시 이벤트 유실 가능 — DLQ 및 Consumer 로그 확인.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "targets": [
        {
          "expr": "sum(rate(ft_kafka_events_total[1m])) by (topic, action, result)",
          "legendFormat": "{{topic}} / {{action}} / {{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } }
    },

    {
      "id": 50,
      "type": "row",
      "title": "🏆 서비스별 요청 비교",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "barchart",
      "title": "서비스별 총 요청 수 비교 (1분)",
      "description": "서비스 간 트래픽 편중 확인. 특정 서비스에만 집중되면 API Gateway 라우팅 또는 서비스 분리 검토.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count[1m])) by (application)",
          "legendFormat": "{{application}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 52,
      "type": "barchart",
      "title": "서비스별 P95 응답시간 비교",
      "description": "서비스 간 P95 응답시간 비교. 특정 서비스만 높으면 해당 서비스 DB 쿼리·외부 API 호출 지점 점검.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[1m])) by (application, le))",
          "legendFormat": "{{application}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
